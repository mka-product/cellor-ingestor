# S3-compatible object storage (Backblaze B2, AWS S3, etc.)
MINIO_ENDPOINT=s3.eu-central-003.backblazeb2.com
MINIO_ACCESS_KEY=your-key-id
MINIO_SECRET_KEY=your-application-key
MINIO_SECURE=true

# Map all internal virtual buckets (raw, derived, app-state…) into this single real bucket.
# Leave empty to use separate buckets (requires bucket-create permissions).
STORAGE_BUCKET=your-bucket-name

# Use object storage for catalog/overlays/reviews state (set to "file" for local dev with local disk)
STATE_BACKEND=object_store

# Optional: restrict CORS to specific origins (comma-separated). Default allows localhost:5173 for dev.
# CORS_ORIGINS=https://your-app.onrender.com

# Supabase JWT verification (leave empty to disable auth in dev)
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
